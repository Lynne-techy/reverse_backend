{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "setupFiles": ["<rootDir>/setup-e2e.ts"],
  "testRegex": ".e2e-spec.ts$",
  "moduleNameMapper": {
    "^jose$": "<rootDir>/utils/jose-stub.ts"
  },
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  }
}
