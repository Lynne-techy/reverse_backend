# 서버
PORT=3000
NODE_ENV=development

# Supabase (프로젝트 설정 > API 에서 확인)
SUPABASE_URL=https://your-project-ref.supabase.co
# service-role 키: 절대 클라이언트에 노출 금지. 백엔드 전용.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# 보통 ${SUPABASE_URL}/auth/v1
SUPABASE_JWT_ISSUER=https://your-project-ref.supabase.co/auth/v1
# 필사 이미지 저장용 Storage 버킷 이름 (Private)
SUPABASE_STORAGE_BUCKET=writing-images
